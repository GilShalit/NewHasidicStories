@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms

<RadioGroup TValue="LogicalOperator" CheckedValue="@SelectedValue" CheckedValueChanged="@OnSelectedValueChanged" Disabled="@Disabled" class="radio-group">
    <Radio Value="LogicalOperator.Or" Disabled="@Disabled">OR</Radio>
    <Radio Value="LogicalOperator.And" Disabled="@Disabled">AND</Radio>
</RadioGroup>

@code {
    [Inject] GlobalService globalService { get; set; }

    [Parameter] public EventCallback<LogicalOperator> SelectedValueChanged { get; set; }

    [Parameter] public LogicalOperator SelectedValue { get; set; }

    [Parameter] public bool Disabled { get; set; } = false;

    private async Task OnSelectedValueChanged(LogicalOperator newValue)
    {
        SelectedValue = newValue;
        await SelectedValueChanged.InvokeAsync(newValue);
    }
}